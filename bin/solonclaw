#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_JAR_NAME="solonclaw-0.0.1.jar"
RUNTIME_JAR="$ROOT/$DEFAULT_JAR_NAME"
DEV_JAR="$ROOT/target/$DEFAULT_JAR_NAME"

# 运行包优先使用根目录 jar，源码开发时回退到 target/ 下的构建产物。
if [ -n "${SOLONCLAW_JAR:-}" ]; then
    JAR="$SOLONCLAW_JAR"
elif [ -f "$RUNTIME_JAR" ]; then
    JAR="$RUNTIME_JAR"
else
    JAR="$DEV_JAR"
fi

# Node TUI 是运行包中的独立前端入口；可通过环境变量覆盖以便本地调试。
TERMINAL_UI="${SOLONCLAW_TERMINAL_UI:-$ROOT/terminal-ui/dist/entry.js}"
JAVA_RUNTIME_ARGS=()
SOLONCLAW_WORKSPACE="${SOLONCLAW_WORKSPACE:-}"
# 指定 workspace 时同步 SOLONCLAW_HOME，保证后端和终端 UI 看到同一目录。
if [ -n "$SOLONCLAW_WORKSPACE" ]; then
    JAVA_RUNTIME_ARGS=("-Dsolonclaw.workspace=$SOLONCLAW_WORKSPACE")
    export SOLONCLAW_HOME="${SOLONCLAW_HOME:-$SOLONCLAW_WORKSPACE}"
elif [ "$JAR" = "$RUNTIME_JAR" ]; then
    # 发布包以包根目录作为 workspace，符合 target/solonclaw-workspace 的布局约定。
    JAVA_RUNTIME_ARGS=("-Dsolonclaw.workspace=$ROOT")
    export SOLONCLAW_HOME="${SOLONCLAW_HOME:-$ROOT}"
fi

require_jar() {
    if [ ! -f "$JAR" ]; then
        echo "Error: backend jar not found: $JAR" >&2
        echo "Run: mvn -DskipTests package" >&2
        exit 1
    fi
}

# server/completion 命令由后端 Java 进程处理，其余交互默认进入 Node TUI。
if [ "${1:-}" = "server" ]; then
    shift
    require_jar
    exec java "${JAVA_RUNTIME_ARGS[@]}" -jar "$JAR" server "$@"
fi

if [ "${1:-}" = "completion" ] || [ "${1:-}" = "--completion" ]; then
    require_jar
    exec java "${JAVA_RUNTIME_ARGS[@]}" -jar "$JAR" "$@"
fi

if [ ! -f "$TERMINAL_UI" ]; then
    echo "Error: terminal UI is not built: $TERMINAL_UI" >&2
    echo "Run: mvn -DskipTests package" >&2
    exit 1
fi

exec node "$TERMINAL_UI" "$@"
