{
  "name": "solonclaw",
  "version": "0.0.8",
  "description": "Terminal UI for solonclaw agent service",
  "type": "module",
  "bin": {
    "solonclaw": "./dist/entry.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run build --prefix packages/solonclaw-ink && tsx --watch src/entry.tsx",
    "prestart": "npm run build --prefix packages/solonclaw-ink",
    "start": "tsx src/entry.tsx",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build && node -e \"const fs=require('fs');const f='dist/entry.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/ packages/",
    "lint:fix": "eslint src/ packages/ --fix",
    "fmt": "prettier --write 'src/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}'",
    "fix": "npm run lint:fix && npm run fmt",
    "pretest": "npm run build --prefix packages/solonclaw-ink",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@nanostores/react": "^1.1.0",
    "@solonclaw/ink": "file:./packages/solonclaw-ink",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "esbuild": "~0.27.0",
    "eslint": "^9",
    "eslint-plugin-perfectionist": "^5",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-unused-imports": "^4",
    "globals": "^16",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "nanostores": "^1.2.0",
    "prettier": "^3",
    "react": "^19.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "unicode-animations": "^1.0.3",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "zod-validation-error": "^4.0.2"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chengliang4810/solon-claw.git",
    "directory": "terminal-ui"
  },
  "keywords": [
    "solonclaw",
    "tui",
    "terminal",
    "agent",
    "ai"
  ],
  "dependencies": {
    "ws": "^8.21.0"
  }
}
